LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional server-only access code. When set, visitors unlock once via /api/gate
# (httpOnly cookie) before /api/token mints a LiveKit JWT. Never expose this as
# NEXT_PUBLIC_* — a client-bundled secret cannot protect the endpoint.
# Leave unset for open local demos; set before any public deploy.
# APP_SECRET=

# Set to 1 to enable per-IP buckets via trusted platform headers only:
#   - cf-connecting-ip (Cloudflare)
#   - x-vercel-forwarded-for (Vercel; overwrites client-supplied values)
#   - x-real-ip (only if your proxy replaces it with the verified peer address)
# Do NOT enable solely because traffic passes Cloudflare or nginx: those often
# append X-Forwarded-For, and this app deliberately ignores that header.
# Without a matching platform header, limits stay on a shared global bucket.
# TRUST_PROXY=1
